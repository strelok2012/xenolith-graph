{
  "$schema": "./tokens.schema.json",
  "name": "xen",
  "version": "0.0.0",
  "color": {
    "brand": {
      "primary":       "#FCB400",
      "primaryDark":   "#C28B00",
      "primaryDeep":   "#68531D",
      "primaryLight":  "#FFDF67",
      "primaryPale":   "#FFEDA8",
      "primaryAlpha20": "rgba(252, 180, 0, 0.2)",
      "primaryAlpha30": "rgba(252, 180, 0, 0.3)",
      "primaryAlpha50": "rgba(252, 180, 0, 0.5)",
      "primaryAlpha60": "rgba(255, 237, 168, 0.6)"
    },
    "surface": {
      "canvas":   "#1A1A1A",
      "node":     "#0F110E",
      "panel":    "#191919",
      "elevated": "#232323",
      "muted":    "#292929",
      "subtle":   "#363636",
      "outline":  "#424242",
      "divider":  "#363636",
      "headerEnd": "#30342E"
    },
    "text": {
      "primary":   "#FFFFFF",
      "secondary": "#B8B8B8",
      "muted":     "rgba(255, 255, 255, 0.5)",
      "disabled":  "rgba(255, 255, 255, 0.3)"
    },
    "alpha": {
      "white10":  "rgba(255, 255, 255, 0.1)",
      "white20":  "rgba(255, 255, 255, 0.2)",
      "white30":  "rgba(255, 255, 255, 0.3)",
      "white50":  "rgba(255, 255, 255, 0.5)",
      "dark50":   "rgba(71, 71, 71, 0.5)"
    }
  },
  "pinType": {
    "exec": {
      "label":     "Exec",
      "color":     "#FCB400",
      "shape":     "chevron",
      "edgeColor": "#FCB400",
      "edgeWidth": 3,
      "note":      "Imperative flow. Carries no value, only ordering."
    },
    "float": {
      "label":     "Float",
      "color":     "#85C244",
      "shape":     "circle",
      "edgeColor": "#85C244",
      "edgeWidth": 2
    },
    "object": {
      "label":     "Object",
      "color":     "#3E95B9",
      "shape":     "circle",
      "edgeColor": "#3E95B9",
      "edgeWidth": 2
    },
    "string": {
      "label":     "String",
      "color":     "#FF5622",
      "shape":     "circle",
      "edgeColor": "#FF5622",
      "edgeWidth": 2
    },
    "any": {
      "label":     "Any",
      "color":     "#FFFFFF",
      "shape":     "circle",
      "edgeColor": "#FFFFFF",
      "edgeWidth": 2
    },
    "wildcard": {
      "label":     "Wildcard",
      "color":     "#9AD6E3",
      "shape":     "circle-empty",
      "edgeColor": "#9AD6E3",
      "edgeWidth": 2,
      "note":      "Typed but unconnected; renders with outline only, no fill."
    }
  },
  "category": {
    "logic": {
      "label":    "Logic",
      "accent":   "#85C244",
      "gradient": "linear-gradient(90deg, rgba(133, 194, 68, 0.6) 0%, rgba(48, 52, 46, 0.6) 100%)"
    },
    "data": {
      "label":    "Data",
      "accent":   "#3E95B9",
      "gradient": "linear-gradient(90deg, rgba(62, 149, 185, 0.6) 0%, rgba(48, 52, 46, 0.6) 100%)"
    },
    "macro": {
      "label":    "Macro",
      "accent":   "#8A38F5",
      "gradient": "linear-gradient(90deg, rgba(138, 56, 245, 0.6) 0%, rgba(48, 52, 46, 0.6) 100%)"
    },
    "utility": {
      "label":    "Utility",
      "accent":   "#FFFFFF",
      "gradient": "linear-gradient(90deg, rgba(255, 255, 255, 0.6) 0%, rgba(48, 52, 46, 0.6) 100%)"
    }
  },
  "pill": {
    "orange": "linear-gradient(90deg, rgba(15, 17, 14, 0.5) 12.63%, rgba(255, 86, 34, 0.3) 51.57%, rgba(15, 17, 14, 0.5) 90.91%), #0F110E",
    "green":  "linear-gradient(90deg, rgba(15, 17, 14, 0.5) 12.63%, rgba(133, 194, 68, 0.3) 51.57%, rgba(15, 17, 14, 0.5) 90.91%), #0F110E"
  },
  "state": {
    "hover": {
      "border":      "#FCB400",
      "borderWidth": 1,
      "glow":        "rgba(252, 180, 0, 0.52)",
      "glowBlur":    4
    },
    "selected": {
      "border":      "#FFFFFF",
      "borderWidth": 1,
      "glow":        "rgba(255, 255, 255, 0.4)",
      "glowBlur":    5
    },
    "active": {
      "border":      "#FFDF67",
      "borderWidth": 1,
      "glow":        "rgba(252, 180, 0, 0.64)",
      "glowBlur":    6
    },
    "disabled": {
      "opacity": 0.4
    }
  },
  "geometry": {
    "node": {
      "radius":        7,
      "minWidth":      150,
      "headerHeight":  21,
      "headerPadding": 2,
      "innerPaddingX": 4,
      "innerPaddingY": 4,
      "pillRadius":    20,
      "pillHeight":    40,
      "pillMinWidth":  140
    },
    "pin": {
      "diameter":         8,
      "stroke":           1,
      "strokeColor":      "#1A1A1A",
      "labelGap":         7,
      "rowSpacing":       10,
      "rowHeight":        11,
      "hitPadding":       4,
      "chevronExecWidth": 10,
      "chevronExecHeight": 8
    },
    "header": {
      "toPinsGap":   15,
      "chevronSize": 16,
      "titleGap":    5
    },
    "edge": {
      "width":               2,
      "execWidth":           3,
      "bezierTension":       0.5,
      "minHorizontalSpread": 50,
      "hitPadding":          6,
      "pulseEnabled":        true
    },
    "comment": {
      "radius":        6,
      "headerHeight":  20,
      "minWidth":      120,
      "minHeight":     80
    }
  },
  "typography": {
    "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif",
    "heading": {
      "size":       12,
      "weight":     700,
      "lineHeight": 14,
      "color":      "#FFFFFF",
      "tracking":   0
    },
    "label": {
      "size":       10,
      "weight":     400,
      "lineHeight": 11,
      "color":      "#FFFFFF",
      "tracking":   0
    },
    "comment": {
      "size":       14,
      "weight":     600,
      "lineHeight": 18,
      "color":      "#FFFFFF",
      "tracking":   0
    }
  },
  "effect": {
    "headerInnerShadow": {
      "offsetX": 0,
      "offsetY": 3,
      "blur":    6,
      "color":   "rgba(255, 255, 255, 0.5)"
    },
    "pillInnerShadow": {
      "offsetX": 0,
      "offsetY": 4,
      "blur":    4,
      "color":   "rgba(255, 255, 255, 0.15)"
    },
    "headerBackdropBlur": 4,
    "pillBackdropBlur":   2,
    "headerHighlightGradient": "linear-gradient(180deg, #FFFFFF 14.29%, rgba(153, 153, 153, 0) 57.14%)",
    "headerHighlightStroke": "linear-gradient(180deg, #FFFFFF 0%, rgba(153, 153, 153, 0) 100%)",
    "nodeDropShadow": {
      "offsetX": 0,
      "offsetY": 8,
      "blur":    18,
      "color":   "rgba(0, 0, 0, 0.85)"
    }
  },
  "background": {
    "color": "#1A1A1A",
    "grid": {
      "kind":    "dots",
      "spacing": 24,
      "size":    1,
      "color":   "rgba(255, 255, 255, 0.3)"
    }
  },
  "edgeRouting": {
    "rule": "edgeColorFollowsSourcePinType",
    "note": "Invariant: every edge inherits the colour of its source pin's type. Per-edge overrides are allowed but discouraged outside special UI states (e.g. error highlighting)."
  }
}
