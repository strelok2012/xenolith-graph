{
  "name": "@xenolith/plugin-autolayout",
  "version": "0.0.0",
  "description": "Auto-layout plugin for XenolithGraph. Engine-agnostic: bring your own layout backend (dagre / elkjs / custom) via the LayoutEngine interface.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dagre": {
      "types": "./dist/adapters/dagre.d.ts",
      "import": "./dist/adapters/dagre.js"
    },
    "./elk": {
      "types": "./dist/adapters/elk.d.ts",
      "import": "./dist/adapters/elk.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "dependencies": {
    "@xenolith/core": "workspace:*",
    "@xenolith/editor": "workspace:*"
  },
  "peerDependencies": {
    "dagre": "^0.8.5",
    "elkjs": "^0.9.0 || ^0.10.0 || ^0.11.0"
  },
  "peerDependenciesMeta": {
    "dagre": {
      "optional": true
    },
    "elkjs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
