---
import '../styles/fonts.css'
import '../styles/theme.css'
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>XenolithGraph — Playground</title>
    <link rel="icon" href="/xenolith-graph/favicon-64.png" />
    <style>
      html, body { margin: 0; padding: 0; height: 100%; background: #1A1A1A; color: #FFFFFF; overflow: hidden; }
      body { font-family: var(--xn-sans); }
      #app { position: fixed; inset: 0; }
      .playground-toolbar {
        position: fixed; top: 16px; left: 16px; z-index: 10;
        display: flex; gap: 12px; align-items: center;
        font-family: var(--xn-display);
        font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
        font-weight: 500;
        color: var(--xn-gold);
        background: rgba(20, 20, 20, 0.78);
        border: 1px solid var(--xn-hair);
        backdrop-filter: blur(8px);
        padding: 8px 14px;
        border-radius: 10px;
      }
      .playground-toolbar a {
        color: var(--xn-bone-dim);
        text-decoration: none;
        font-family: var(--xn-sans);
        letter-spacing: 0;
        text-transform: none;
        font-size: 13px;
      }
      .playground-toolbar a:hover { color: var(--xn-gold-bright); }
      .playground-switcher {
        position: fixed; top: 16px; right: 16px; z-index: 10;
        display: flex; gap: 4px;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.12);
        padding: 4px;
        border-radius: 8px;
      }
      .playground-switcher button {
        font-family: var(--xn-display);
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 500;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        padding: 6px 12px;
        border-radius: 5px;
        cursor: pointer;
      }
      .playground-switcher button.active {
        background: rgba(255, 255, 255, 0.16);
        color: #fff;
      }
      .playground-hint {
        position: fixed; bottom: 16px; left: 16px; z-index: 10;
        font-size: 12px; color: rgba(255,255,255,0.4);
        font-family: var(--xn-sans);
        background: rgba(20, 20, 20, 0.78);
        border: 1px solid var(--xn-hair-soft);
        padding: 8px 12px;
        border-radius: 8px;
        backdrop-filter: blur(8px);
      }
      kbd {
        font-family: var(--xn-mono);
        font-size: 11px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 4px;
        padding: 1px 5px;
      }
    </style>
  </head>
  <body>
    <div class="playground-toolbar">
      <strong>Playground</strong>
      <a href="/xenolith-graph/">← Back to site</a>
    </div>
    <div class="playground-switcher" id="theme-switcher">
      <button data-theme="liquid-glass" class="active">Liquid Glass</button>
      <button data-theme="xen">Xen</button>
    </div>
    <div id="app"></div>
    <div class="playground-hint">
      <kbd>Tab</kbd> / <kbd>Double-click</kbd> insert palette ·
      <kbd>Right-click edge dot</kbd> add node / reroute / delete ·
      <kbd>Wheel</kbd> zoom · <kbd>RMB drag</kbd> pan · <kbd>LMB drag empty</kbd> marquee ·
      <kbd>Drag node</kbd> move (snaps 8px, <kbd>Alt</kbd> to disable) ·
      <kbd>Chevron</kbd> collapse · <kbd>Del</kbd> delete · <kbd>⌘Z</kbd> undo
    </div>
    <script>
      import { XenolithEditor } from '@xenolith/editor'
      import { xenTheme } from '@xenolith/render-pixi'
      import { liquidGlassTheme } from '@xenolith/theme-liquid-glass'
      import { demoGraph, demoSchemas, createCurveWidget, createXYPadWidget } from '@xenolith/demo'

      const THEMES = { 'liquid-glass': liquidGlassTheme, xen: xenTheme }

      const editor = await XenolithEditor.init('#app', {
        theme: liquidGlassTheme,
        zoomBounds: [0.1, 2],
        minimap: true,
      })

      const switcher = document.getElementById('theme-switcher')
      if (switcher) {
        switcher.addEventListener('click', (e) => {
          const target = e.target instanceof HTMLButtonElement ? e.target : null
          const name = target?.dataset.theme
          if (!name) return
          const theme = THEMES[name]
          if (!theme) return
          editor.setTheme(theme)
          for (const btn of switcher.querySelectorAll('button')) {
            btn.classList.toggle('active', btn.dataset.theme === name)
          }
        })
      }

      // Register schemas so Tab / double-click can spawn any node type, then load the whole graph
      // from our own xenolith.v1 data format (both reroute kinds baked in) and frame it.
      editor.registerWidget('curve', createCurveWidget())
      editor.registerWidget('xypad', createXYPadWidget())
      for (const schema of demoSchemas) editor.registry.register(schema)
      editor.loadJSON(demoGraph)
      editor.fitView({ padding: 64, maxZoom: 1 })
    </script>
  </body>
</html>
