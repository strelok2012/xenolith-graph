---
import { Image } from 'astro:assets'
import { Code } from 'astro:components'
import logo from '../assets/logo.png'
import EditorShowcase from './EditorShowcase.astro'

import '../styles/fonts.css'
import '../styles/theme.css'

type Lang = 'en' | 'ru' | 'zh'
interface Props { lang: Lang }
const { lang } = Astro.props

const docPath = lang === 'en' ? '/xenolith-graph/guides/install/' : `/xenolith-graph/${lang}/guides/install/`
const playgroundPath = '/xenolith-graph/playground/'
const examplesPath = '/xenolith-graph/examples/'
const examplesLabel = lang === 'ru' ? 'Примеры' : lang === 'zh' ? '示例' : 'Examples'

const t = (() => {
  if (lang === 'ru') return {
    eyebrow: ['Node-graph редактор', 'WebGL рендер', 'MIT-лицензия'],
    h1:      'Красивое нодовое редактирование — готово к встраиванию.',
    sub:     'Полированный node-graph редактор для веба — добавьте его в своё приложение, темизируйте, сохраняйте и восстанавливайте. Перетаскивайте, соединяйте, ныряйте в подграфы, вставляйте по Tab. Всё уже подключено в момент монтирования. Откройте playground или галерею примеров — оцените за минуту.',
    ctaPrimary:   'Открыть документацию',
    ctaSecondary: 'GitHub',
    showcaseA: 'Xen — тема по умолчанию',
    showcaseB: 'Liquid Glass — вдохновлено новым дизайном Apple',
    showcaseSub: 'Один и тот же граф, отрисованный двумя совершенно разными способами — переключаются в рантайме одной строкой. Liquid Glass даёт нодам настоящий стеклянный материал с преломлением и размытием фона.',
    metrics: [
      { v: '6',   l: 'фреймворк-адаптеров' },
      { v: '60', l: 'fps на 500 нодах' },
      { v: 'MIT', l: 'open-source лицензия' },
    ],
    featuresTitle: 'Что внутри',
    featuresSub: 'Всё что нужно реальному редактору графов из коробки — UX, модель, темы, плагины. Берите то что нужно — остальное не мешает.',
    features: [
      { n: '01', h: 'Две темы, runtime-смена',
        p: 'Xen — production-ready по умолчанию; Liquid Glass — стеклянный материал с преломлением и размытием фона. setTheme() переключает между ними вживую. Берите готовое, пишите свою или подключайте третью.' },
      { n: '02', h: 'Под любой фреймворк',
        p: 'Первородные адаптеры для React, Vue, Svelte, Solid, Angular и Web Components — плюс vanilla-путь без зависимостей. Ядро framework-agnostic, zero-dep, headless.' },
      { n: '03', h: 'Палитра вставки · команды · хоткеи',
        p: 'Tab открывает fuzzy-поиск по палитре. Регистрируйте именованные команды и привязывайте хоткеи (Mod+Z, Cmd+Shift+K) — ваши шорткаты живут рядом со встроенными. Tab-drag с пустого пина создаёт совместимую ноду на drop.' },
      { n: '04', h: 'Пины, рёбра, multi-drag',
        p: 'Типизированные пины с проверкой совместимости и регистрируемыми конверсиями. Marquee-выбор, snap к сетке, Alt-rewire, лейблы на рёбрах, стрелки, анимированные рёбра, четыре стиля пути (bezier, smoothstep, step, linear).' },
      { n: '05', h: 'Виджеты внутри нод',
        p: 'Декларативные number, slider, combo, text, toggle, color, button — плюс кастомные canvas-draw и DOM-mounted контроллеры (React / Vue / Svelte тоже работают). Условная видимость по состоянию, properties-sidebar, live-значения на display-виджетах.' },
      { n: '06', h: 'Макросы, шаблоны, подграфы',
        p: 'Сгруппируйте выборку в inline-макро или вытащите как переиспользуемый template для повторных инстансов. Double-click — нырок внутрь, breadcrumb отслеживает путь. Конверсия макро ↔ template в обе стороны.' },
      { n: '07', h: 'Save, restore, export',
        p: 'Версионированный xenolith.v1 JSON с per-schema migrate-хуками — старые графы апгрейдятся автоматически. Встроен импортёр workflow ComfyUI. Экспорт ВСЕГО графа (а не viewport) в PNG или JPEG любого разрешения.' },
      { n: '08', h: 'Auto-layout · minimap · большие графы',
        p: 'Plug-in адаптеры для Dagre и ELK раскладывают граф одним вызовом (с анимацией tween). Встроенная мини-карта, виртуализация viewport после 300 нод, level-of-detail рендеринг, встроенная панель свойств которая следует за выборкой.' },
    ],
    quickStartTitle: 'Старт за 30 секунд',
    quickStartCode: `import { XenolithEditor } from '@xenolith/editor'

// Один вызов — фонты, PIXI, viewport, grid, interaction уже подняты.
const editor = await XenolithEditor.init('#app')

// Загрузите граф или соберите его — зарегистрируйте схемы и спавните из палитры.
editor.loadJSON(myGraph)

// Готово. Drag, connect, undo, dive, snap, save — всё уже работает.`,
    finalH:   'Готов к интеграции',
    finalP:   'MIT-лицензия, опубликован в npm. Сделан для frontend AI-workflow, shader/материал-редакторов, dataflow-редакторов и любого нодового UI. PR и issues приветствуются.',
    finalCta: 'Документация →',
  }
  if (lang === 'zh') return {
    eyebrow: ['节点图编辑器', 'WebGL 渲染', 'MIT 许可证'],
    h1:      '精美的节点编辑 — 为嵌入而生。',
    sub:     '面向 Web 的精雕节点图编辑器 — 嵌入任意应用、自定义主题、保存与恢复。拖拽、连线、深入子图、按 Tab 插入节点。编辑器挂载即刻可用。访问 playground 或示例画廊，一分钟内即可上手。',
    ctaPrimary:   '查看文档',
    ctaSecondary: 'GitHub',
    showcaseA: 'Xen — 默认主题',
    showcaseB: 'Liquid Glass — 灵感源自苹果全新设计',
    showcaseSub: '同一个图，两种截然不同的主题，运行时一行切换。Liquid Glass 为节点赋予真实的玻璃材质，带折射与背景模糊。',
    metrics: [
      { v: '6',   l: '框架适配器' },
      { v: '60', l: 'fps / 500 节点' },
      { v: 'MIT', l: '开源许可证' },
    ],
    featuresTitle: '内置什么',
    featuresSub:   '真实图编辑器所需的一切，开箱即用 — UX、模型、主题、插件。需要什么就用什么，其余不挡路。',
    features: [
      { n: '01', h: '两种主题，运行时切换',
        p: 'Xen 是生产就绪的默认主题；Liquid Glass 提供真实玻璃材质，带折射与背景模糊。setTheme() 实时切换。选用其一、自定义或写第三套。' },
      { n: '02', h: '任意框架皆可',
        p: '为 React、Vue、Svelte、Solid、Angular 与 Web Components 提供官方适配器，也支持纯 vanilla。核心框架无关、零依赖、headless。' },
      { n: '03', h: '插入面板 · 命令 · 快捷键',
        p: 'Tab 打开模糊搜索面板。注册命名命令并绑定快捷键（Mod+Z、Cmd+Shift+K）— 您的快捷键与内置共存。从空引脚 Tab-drag 即可在松开时生成兼容节点。' },
      { n: '04', h: '引脚、连线、多选拖动',
        p: '类型化引脚带兼容检查与可注册的类型转换。框选、网格吸附、Alt 重连、连线标签、箭头、动画连线、四种路径风格（bezier、smoothstep、step、linear）。' },
      { n: '05', h: '节点内置部件',
        p: '声明式 number、slider、combo、text、toggle、color、button — 加上自定义 canvas 与 DOM 挂载控件（React / Vue / Svelte 都行）。基于状态的条件可见性、属性侧栏、display 部件实时取值。' },
      { n: '06', h: '宏、模板、子图',
        p: '将选区组合成内嵌宏，或抽取为可复用的 template 以批量实例化。双击进入；面包屑追踪路径。宏与 template 双向互转。' },
      { n: '07', h: '保存、恢复、导出',
        p: '版本化的 xenolith.v1 JSON，附带每个 schema 的 migrate 钩子 — 旧图自动升级。内置 ComfyUI workflow 导入器。导出整张图（而非视口）为任意分辨率的 PNG 或 JPEG。' },
      { n: '08', h: '自动布局 · 缩略图 · 大图',
        p: 'Dagre 与 ELK 适配器一次调用即可排版（带 tween 动画）。内置 minimap、超过 300 节点后启用视口虚拟化、LOD 渲染、随选区移动的属性面板。' },
    ],
    quickStartTitle: '30 秒上手',
    quickStartCode: `import { XenolithEditor } from '@xenolith/editor'

// 一次调用——字体、PIXI、视口、栅格、交互全部就绪。
const editor = await XenolithEditor.init('#app')

// 加载图，或注册 schema 后从面板生成节点。
editor.loadJSON(myGraph)

// 完成。拖拽、连线、撤销、深入、吸附、保存——一切都已工作。`,
    finalH:   '可立即集成',
    finalP:   'MIT 许可证。发布在 npm。为 AI 工作流前端、shader 与材质编辑器、dataflow 编辑器以及任意节点 UI 打造。欢迎 PR 与 issue。',
    finalCta: '文档 →',
  }
  return {
    eyebrow: ['Node-graph editor', 'WebGL renderer', 'MIT licence'],
    h1:      'Beautiful node editing. Built to embed.',
    sub:     'A polished node-graph editor for the web — drop it in your app, theme it, save and restore it. Drag, connect, dive into subgraphs, hit Tab to insert. Everything is already wired the moment the editor mounts. Tour the playground or the example gallery to feel it in under a minute.',
    ctaPrimary:   'Open documentation',
    ctaSecondary: 'GitHub',
    showcaseA: 'Xen — the default theme',
    showcaseB: 'Liquid Glass — inspired by new Apple design',
    showcaseSub: 'The same graph rendered two completely different ways — swapped at runtime in a single line. Liquid Glass gives every node a real glass material with refraction and a blurred backdrop.',
    metrics: [
      { v: '6',   l: 'framework adapters' },
      { v: '60', l: 'fps on 500 nodes' },
      { v: 'MIT', l: 'open-source licence' },
    ],
    featuresTitle: 'What is inside',
    featuresSub: 'Everything a real-world graph editor needs out of the box — UX, model, themes, plugins. Pick the parts you want, the rest stays out of the way.',
    features: [
      { n: '01', h: 'Two themes, runtime swap',
        p: 'Xen is the production-ready default; Liquid Glass adds a real glass material with refraction and a blurred backdrop. setTheme() switches between them live — pick one, ship your own, or write a third.' },
      { n: '02', h: 'Built for any framework',
        p: 'First-party adapters for React, Vue, Svelte, Solid, Angular and Web Components — and a vanilla path that needs nothing. The core is framework-agnostic, zero-dep, headless.' },
      { n: '03', h: 'Insert palette · commands · hotkeys',
        p: 'Tab opens a fuzzy-search palette. Register named commands and bind hotkeys (Mod+Z, Cmd+Shift+K) — your shortcuts coexist with built-ins. Tab-drag from an empty pin spawns a compatible node on drop.' },
      { n: '04', h: 'Pins, edges, multi-drag',
        p: 'Typed pins with compatibility checks and registerable conversions. Marquee-select, snap-to-grid, Alt-rewire, edge labels, arrowheads, animated edges, four path styles (bezier, smoothstep, step, linear).' },
      { n: '05', h: 'Widgets inside nodes',
        p: 'Declarative number, slider, combo, text, toggle, colour, button — plus custom canvas-drawn and DOM-mounted controllers (React / Vue / Svelte work too). Conditional visibility on widget state, properties sidebar, live values on display widgets.' },
      { n: '06', h: 'Macros, templates, subgraphs',
        p: 'Group a selection into an inline macro, or extract it as a reusable template you can instantiate elsewhere. Double-click to dive in; a breadcrumb tracks the path. Convert between macro and template either direction.' },
      { n: '07', h: 'Save, restore, export',
        p: 'Versioned xenolith.v1 JSON with per-schema migrate hooks — old graphs upgrade automatically. ComfyUI workflow importer included. Export the entire graph (not just the viewport) to PNG or JPEG at any resolution.' },
      { n: '08', h: 'Auto-layout · minimap · large graphs',
        p: 'Drop-in plugins for Dagre and ELK arrange any graph with one call (animated tweens included). Built-in minimap, viewport virtualisation past 300 nodes, level-of-detail rendering, and an in-editor properties panel that travels with your selection.' },
    ],
    quickStartTitle: '30-second start',
    quickStartCode: `import { XenolithEditor } from '@xenolith/editor'

// One call — fonts, PIXI, viewport, grid, interactions are wired.
const editor = await XenolithEditor.init('#app')

// Load a graph, or build one by registering schemas + spawning from the palette.
editor.loadJSON(myGraph)

// Done. Drag, connect, undo, dive, snap, save — they all just work.`,
    finalH:   'Ready to embed',
    finalP:   'MIT licence, published on npm. Built for AI-workflow front-ends, shader and material editors, dataflow editors, anything node-based. PRs and issues welcome.',
    finalCta: 'Documentation →',
  }
})()

---

<div class="xn-landing">
  <section class="xn-hero">
    <div class="xn-hero-left">
      <div class="xn-eyebrow-row">
        {t.eyebrow.map((e) => <span class="xn-eyebrow">{e}</span>)}
      </div>
      <h1 class="xn-h1">{t.h1}</h1>
      <p class="xn-hero-sub">{t.sub}</p>
      <div class="xn-cta-row">
        <a class="xn-btn xn-btn-primary" href={docPath}>{t.ctaPrimary} <span aria-hidden="true">→</span></a>
        <a class="xn-btn xn-btn-ghost" href={playgroundPath}>{lang === 'ru' ? 'Открыть playground' : lang === 'zh' ? '打开 playground' : 'Open playground'}</a>
        <a class="xn-btn xn-btn-ghost" href={examplesPath}>{examplesLabel}</a>
        <a class="xn-btn xn-btn-ghost" href="https://github.com/XenolithEngine/xenolith-graph">{t.ctaSecondary}</a>
      </div>
    </div>
    <div class="xn-hero-emblem">
      <Image src={logo} alt="XenolithGraph" width={320} height={320} />
      <div class="xn-emblem-glow"></div>
    </div>
  </section>

  <ul class="xn-metrics">
    {t.metrics.map((m) => (
      <li>
        <div class="xn-metric-v">{m.v}</div>
        <div class="xn-metric-l">{m.l}</div>
      </li>
    ))}
  </ul>

  <section class="xn-showcase-section">
    <h2 class="xn-h2">{t.showcaseA} · {t.showcaseB}</h2>
    <p class="xn-h2-sub">{t.showcaseSub}</p>
    <div class="xn-showcase-row">
      <EditorShowcase id="hero-xen"          label={t.showcaseA} themeName="xen" />
      <EditorShowcase id="hero-liquid-glass" label={t.showcaseB} themeName="liquid-glass" />
    </div>
  </section>

  <section class="xn-features">
    <header>
      <h2 class="xn-h2">{t.featuresTitle}</h2>
      <p class="xn-h2-sub">{t.featuresSub}</p>
    </header>
    <ul class="xn-feature-grid">
      {t.features.map((f) => (
        <li class="xn-feature">
          <div class="xn-feature-num">{f.n}</div>
          <h3>{f.h}</h3>
          <p>{f.p}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="xn-quickstart">
    <h2 class="xn-h2">{t.quickStartTitle}</h2>
    <Code code={t.quickStartCode} lang="ts" theme="vesper" />
  </section>

  <section class="xn-final">
    <h2 class="xn-h2 xn-final-h">{t.finalH}</h2>
    <p>{t.finalP}</p>
    <a class="xn-btn xn-btn-primary" href={docPath}>{t.finalCta}</a>
  </section>
</div>

<style>
  /* PIXI appends <canvas> at runtime so it has no Astro scope hash — use :global() so the
   * selectors match. Otherwise canvas overrides parent's aspect-ratio: 16/10. */
  :global(.xn-showcase) {
    position: relative;
    background: var(--xn-ink-2);
    border-radius: 14px;
    border: 1px solid var(--xn-hair-soft);
    overflow: hidden;
    width: 100%;
    aspect-ratio: 16 / 10;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
  }
  :global(.xn-showcase > canvas) {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    display: block;
  }
  :global(.xn-showcase-label) {
    position: absolute;
    top: 14px; left: 14px;
    font-family: var(--xn-display);
    font-size: 11px; letter-spacing: 0.16em;
    text-transform: uppercase; font-weight: 500;
    color: var(--xn-gold);
    background: var(--xn-grad-gold-soft);
    border: 1px solid var(--xn-hair);
    padding: 6px 10px;
    border-radius: 8px;
    z-index: 2;
    pointer-events: none;
  }
  /* Override Starlight's `.sl-markdown-content code` rule for our hero inline code. */
  :global(.sl-markdown-content .xn-h1-code),
  :global(.xn-landing .xn-h1-code) {
    background: var(--xn-grad-gold-frame);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    border: none !important;
    padding: 0 !important;
    font-family: var(--xn-mono);
    font-weight: 600;
    font-size: 0.85em;
  }

  .xn-landing {
    --hpad: clamp(20px, 4vw, 56px);
    color: var(--xn-bone);
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--hpad) 96px;
  }

  /* HERO */
  .xn-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
    padding: 40px 0 32px;
  }
  @media (max-width: 880px) {
    .xn-hero { grid-template-columns: 1fr; gap: 32px; }
    .xn-hero-emblem { order: -1; }
  }
  .xn-eyebrow-row {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-bottom: 14px;
    margin-top: 0;
  }
  .xn-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--xn-display);
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 500;
    color: var(--xn-gold);
    border: 1px solid rgba(217, 202, 160, 0.28);
    background: var(--xn-grad-gold-soft);
    padding: 6px 12px;
    border-radius: 10px;
  }
  .xn-h1 {
    font-family: var(--xn-display);
    font-weight: 500;
    font-size: clamp(40px, 5.4vw, 62px);
    line-height: 1.05;
    letter-spacing: 0.005em;
    margin: 0 0 16px;
    color: var(--xn-bone);
  }
  .xn-h1-code {
    font-family: var(--xn-mono);
    font-weight: 600;
    background: var(--xn-grad-gold-frame);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    font-size: 0.85em;
  }
  .xn-hero-sub {
    color: var(--xn-bone-dim);
    font-size: 17px;
    line-height: 1.55;
    max-width: 58ch;
    margin: 0 0 32px;
  }
  .xn-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }

  .xn-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    font-family: var(--xn-sans);
    font-size: 12px; font-weight: 800;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: #FFFFFF;
    padding: 13px 28px; border-radius: 10px;
    text-decoration: none;
    transition: filter .15s ease, transform .15s ease, border-color .15s ease;
  }
  .xn-btn-primary {
    background: var(--xn-grad-gold-soft), #1F1F1F;
    border: 1px solid transparent;
    background-clip: padding-box;
    box-shadow:
      inset 0 0 0 1px rgba(217, 202, 160, 0.4),
      0 1px 0 rgba(255, 247, 215, 0.08) inset,
      0 14px 36px rgba(99, 83, 23, 0.32);
  }
  .xn-btn-primary:hover { filter: brightness(1.18); transform: translateY(-1px); }
  .xn-btn-primary span[aria-hidden] { color: var(--xn-gold); font-weight: 700; }
  .xn-btn-ghost {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .xn-btn-ghost:hover { border-color: rgba(217, 202, 160, 0.55); color: var(--xn-gold); }

  .xn-hero-emblem {
    position: relative;
    display: flex; justify-content: center; align-items: center;
  }
  .xn-hero-emblem :global(img) {
    width: 100%; max-width: 320px; height: auto;
    filter: drop-shadow(0 24px 48px rgba(0,0,0,0.45));
  }
  .xn-emblem-glow {
    position: absolute; inset: 8%;
    background: radial-gradient(circle, rgba(217, 202, 160, 0.22), transparent 60%);
    z-index: -1; filter: blur(48px);
  }

  /* METRICS */
  .xn-metrics {
    list-style: none; margin: 32px 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  @media (max-width: 720px) { .xn-metrics { grid-template-columns: 1fr; } }
  .xn-metrics li {
    border: 1px solid var(--xn-hair-soft);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.015);
    padding: 18px;
  }
  .xn-metric-v {
    font-family: var(--xn-display);
    font-size: 28px; font-weight: 500;
    color: var(--xn-gold-bright);
    margin-bottom: 4px;
  }
  .xn-metric-l {
