---
import { Code } from 'astro:components'
import { FRAMEWORKS, type ExampleDef, type Framework } from '../examples/manifest.ts'

interface CodeFile { framework: Framework; name: string; code: string; lang: string }
interface Props { example: ExampleDef; files: CodeFile[] }
const { example, files } = Astro.props as Props

const readyFw = FRAMEWORKS.filter((f) => example.impls[f.key])
const active: Framework = readyFw[0]?.key ?? 'react'
const filesByFw = (fw: Framework): CodeFile[] => files.filter((f) => f.framework === fw)

// Brand logo (simple-icons path, 24×24 viewBox) in the framework's brand colour, before its name.
