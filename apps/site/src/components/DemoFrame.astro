---

<div class="dfr" data-demoframe>
  <div class="dfr-preview">
    <slot />
  </div>

  <div class="dfr-bar">
    <div class="dfr-switch">
      {FRAMEWORKS.map((f) => (
        example.impls[f.key]
          ? <button class={`dfr-chip${f.key === active ? ' active' : ''}`} data-fw-chip={f.key} title={f.label}>
              <svg class="dfr-fwi" viewBox="0 0 24 24" aria-hidden="true"><path d={FW_ICON[f.key].path} fill={FW_ICON[f.key].color} /></svg>
              {f.label}
            </button>
          : <button class="dfr-chip" disabled title={`${f.label} — coming soon`}>
              <svg class="dfr-fwi" viewBox="0 0 24 24" aria-hidden="true"><path d={FW_ICON[f.key].path} fill={FW_ICON[f.key].color} /></svg>
              {f.label}<span class="dfr-soon">soon</span>
            </button>
      ))}
    </div>
    <div class="dfr-actions">
      <button class="dfr-icon" data-action="code" title="Show code" aria-label="Show code">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      </button>
      <button class="dfr-icon" data-action="reset" data-id={example.id} title="Reset preview" aria-label="Reset preview">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
      </button>
      <button class="dfr-icon" data-action="stackblitz" disabled title="Open in StackBlitz — available once packages are published to npm" aria-label="Open in StackBlitz">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </button>
    </div>
  </div>

  <div class="dfr-codewrap" hidden>
    <button class="dfr-copy" data-action="copy" title="Copy code" aria-label="Copy code">
      <svg class="dfr-copy-i" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    </button>
    {readyFw.map((f) => (
      <div data-fw-code={f.key} class={f.key === active ? '' : 'dfr-hidden'}>
        <div class="dfr-tabs">
          {filesByFw(f.key).map((file, i) => (
            <button class={`dfr-tab${i === 0 ? ' active' : ''}`} data-tab={i}>{file.name}</button>
          ))}
        </div>
        {filesByFw(f.key).map((file, i) => (
          <div class={`dfr-panel${i === 0 ? '' : ' dfr-hidden'}`} data-panel={i}>
            <Code code={file.code} lang={file.lang} theme="vesper" />
          </div>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .dfr { border: 1px solid var(--xn-hair, #2a2a2a); border-radius: 12px; overflow: hidden; background: #161616; }
  .dfr-preview { position: relative; height: 460px; background: #1A1A1A; }
  .dfr-bar { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 8px 10px; border-top: 1px solid #2a2a2a; flex-wrap: wrap; }
  .dfr-switch, .dfr-actions { display: flex; gap: 6px; align-items: center; }
  .dfr-chip { font: inherit; font-size: 12px; padding: 5px 10px; border-radius: 7px; border: 1px solid #333; background: #1d1d1d; color: #cfcfcf; cursor: pointer; display: inline-flex; gap: 6px; align-items: center; }
  .dfr-chip.active { background: rgba(252,180,0,.16); border-color: #FCB400; color: #fff; }
  .dfr-chip:disabled { opacity: .5; cursor: default; }
  .dfr-fwi { width: 15px; height: 15px; flex: none; display: block; }
  .dfr-soon { font-size: 9px; text-transform: uppercase; letter-spacing: .06em; opacity: .7; border: 1px solid currentColor; border-radius: 4px; padding: 0 3px; }
  .dfr-icon { display: grid; place-items: center; width: 30px; height: 30px; border-radius: 7px; border: 1px solid #333; background: #1d1d1d; color: #cfcfcf; cursor: pointer; }
  .dfr-icon:hover:not(:disabled) { background: #2a2a2a; color: #fff; }
  .dfr-icon.active { background: rgba(252,180,0,.16); border-color: #FCB400; color: #fff; }
  .dfr-icon:disabled { opacity: .4; cursor: default; }
  .dfr-codewrap { border-top: 1px solid #2a2a2a; position: relative; }
  .dfr-copy { position: absolute; top: 7px; right: 8px; z-index: 2; display: grid; place-items: center; width: 28px; height: 28px; border-radius: 7px; border: 1px solid #333; background: rgba(22,22,22,.85); color: #cfcfcf; cursor: pointer; }
  .dfr-copy:hover { background: #2a2a2a; color: #fff; }
  .dfr-copy.copied { color: var(--xn-gold, #FCB400); border-color: var(--xn-gold, #FCB400); }
  .dfr-tabs { display: flex; gap: 2px; padding: 6px 8px 0; flex-wrap: wrap; background: #0F1010; }
  .dfr-tab { font: inherit; font-size: 12px; padding: 6px 11px; border: none; border-radius: 6px 6px 0 0; background: transparent; color: #9a9a9a; cursor: pointer; }
  .dfr-tab.active { background: #161616; color: #fff; }
  .dfr-hidden { display: none; }
  .dfr-codewrap :global(pre) { margin: 0; border-radius: 0; padding: 16px 20px; max-height: 440px; overflow: auto; }
  .dfr-codewrap :global(pre) :global(code) { display: block; }
</style>

<script>
  for (const root of document.querySelectorAll<HTMLElement>('[data-demoframe]')) {
    const q = <T extends Element>(s: string) => Array.from(root.querySelectorAll<T>(s))
    // Framework switch: swap active chip, the preview panel, and the code group.
    const setFw = (fw: string): void => {
      for (const c of q<HTMLButtonElement>('.dfr-chip')) c.classList.toggle('active', c.dataset.fwChip === fw)
      for (const p of q<HTMLElement>('[data-fw]')) p.classList.toggle('dfr-hidden', p.dataset.fw !== fw)
      for (const g of q<HTMLElement>('[data-fw-code]')) g.classList.toggle('dfr-hidden', g.dataset.fwCode !== fw)
    }
    for (const chip of q<HTMLButtonElement>('.dfr-chip[data-fw-chip]')) {
      chip.addEventListener('click', () => setFw(chip.dataset.fwChip!))
    }
    // Code tabs within the active framework group.
    for (const group of q<HTMLElement>('[data-fw-code]')) {
      const tabs = Array.from(group.querySelectorAll<HTMLButtonElement>('.dfr-tab'))
      const panels = Array.from(group.querySelectorAll<HTMLElement>('.dfr-panel'))
      tabs.forEach((tab) => tab.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.toggle('active', t === tab))
        panels.forEach((p) => p.classList.toggle('dfr-hidden', p.dataset.panel !== tab.dataset.tab))
      }))
    }
    // Toolbar.
    const codewrap = root.querySelector<HTMLElement>('.dfr-codewrap')!
    root.querySelector('[data-action="code"]')!.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLButtonElement
      codewrap.hidden = !codewrap.hidden
      // Keep the icon — just reflect open/closed state via active styling + tooltip.
      btn.classList.toggle('active', !codewrap.hidden)
      const label = codewrap.hidden ? 'Show code' : 'Hide code'
      btn.title = label; btn.setAttribute('aria-label', label)
    })
    root.querySelector('[data-action="reset"]')!.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.id
      document.dispatchEvent(new CustomEvent('xeno:reset', { detail: { id } }))
    })
    // Copy the currently-visible file's code (read from the rendered <pre>).
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-action="copy"]')
    copyBtn?.addEventListener('click', async () => {
      const group = root.querySelector('[data-fw-code]:not(.dfr-hidden)')
      const pre = group?.querySelector('.dfr-panel:not(.dfr-hidden) pre')
      const text = pre?.textContent ?? ''
      try { await navigator.clipboard.writeText(text) } catch { /* clipboard blocked */ }
      copyBtn.classList.add('copied'); copyBtn.title = 'Copied!'
      setTimeout(() => { copyBtn.classList.remove('copied'); copyBtn.title = 'Copy code' }, 1200)
    })
  }
</script>
