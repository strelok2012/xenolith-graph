---
import '../styles/fonts.css'
import '../styles/theme.css'
import { EXAMPLES, CATEGORY_ORDER } from '../examples/manifest.ts'
interface Props { title: string; activeId?: string }
const { title, activeId } = Astro.props as Props
const base = import.meta.env.BASE_URL
const nav = [
  { label: 'Docs', href: `${base}/guides/install/` },
  { label: 'Examples', href: `${base}/examples/` },
  { label: 'Playground', href: `${base}/playground/` },
  { label: 'GitHub', href: 'https://github.com/XenolithEngine/xenolith-graph' },
]
const byCat = CATEGORY_ORDER
  .map((cat) => ({ cat, items: EXAMPLES.filter((e) => e.category === cat) }))
  .filter((g) => g.items.length > 0)
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href={`${base}/favicon-64.png`} />
    <style is:global>
      html, body { margin: 0; background: #121212; color: #e8e8e8; font-family: var(--xn-sans, system-ui, sans-serif); }
      a { color: inherit; }
      .ex-header {
        position: sticky; top: 0; z-index: 20; display: flex; align-items: center; gap: 24px;
        padding: 12px 24px; background: rgba(18,18,18,.85); backdrop-filter: blur(10px);
        border-bottom: 1px solid #232323;
      }
      .ex-brand { font-family: var(--xn-display, var(--xn-sans)); font-weight: 600; letter-spacing: .04em; color: var(--xn-gold, #FCB400); text-decoration: none; font-size: 14px; }
      .ex-nav { display: flex; gap: 18px; }
      .ex-nav a { font-size: 14px; color: #b8b8b8; text-decoration: none; }
      .ex-nav a:hover, .ex-nav a[aria-current="page"] { color: #fff; }
      .ex-body { display: flex; align-items: flex-start; }
      .ex-side {
        position: sticky; top: 49px; align-self: flex-start; flex: 0 0 230px; width: 230px;
        max-height: calc(100vh - 49px); overflow-y: auto; padding: 20px 10px 60px 12px;
        border-right: 1px solid #1f1f1f;
      }
      .ex-side-home { display: block; font-weight: 600; font-size: 15px; text-decoration: none; color: #fff; padding: 6px 10px; border-radius: 8px; margin-bottom: 8px; }
      .ex-side-home.active { background: rgba(252,180,0,.14); color: var(--xn-gold, #FCB400); }
      .ex-side details { margin: 2px 0; }
      .ex-side summary { list-style: none; cursor: pointer; font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: #7a7a7a; padding: 10px 10px 6px; display: flex; justify-content: space-between; align-items: center; }
      .ex-side summary::-webkit-details-marker { display: none; }
      .ex-side summary::after { content: '⌄'; font-size: 13px; transform: translateY(-2px); }
      .ex-side details[open] summary::after { transform: rotate(180deg); }
      .ex-side ul { list-style: none; margin: 0 0 6px; padding: 0 0 0 10px; border-left: 1px solid #232323; }
      .ex-side li a { display: block; font-size: 13.5px; color: #b0b0b0; text-decoration: none; padding: 6px 10px; border-radius: 7px; }
      .ex-side li a:hover { color: #fff; background: #1c1c1c; }
      .ex-side li a.active { color: var(--xn-gold, #FCB400); background: rgba(252,180,0,.12); font-weight: 500; }
      .ex-main { flex: 1; min-width: 0; padding: 32px 28px 80px; }
      @media (max-width: 820px) { .ex-side { display: none; } }
    </style>
  </head>
  <body>
    <header class="ex-header">
      <a class="ex-brand" href={base}>XENOLITHGRAPH</a>
      <nav class="ex-nav">
        {nav.map((n) => (
          <a href={n.href} aria-current={n.label === 'Examples' ? 'page' : undefined}>{n.label}</a>
        ))}
      </nav>
    </header>
    <div class="ex-body">
      <aside class="ex-side">
        <a class={`ex-side-home${activeId ? '' : ' active'}`} href={`${base}/examples/`}>Examples</a>
        {byCat.map((g) => (
          <details open>
            <summary>{g.cat}</summary>
            <ul>
              {g.items.map((e) => (
                <li><a class={e.id === activeId ? 'active' : ''} href={`${base}/examples/${e.id}/`}>{e.title}</a></li>
              ))}
            </ul>
          </details>
        ))}
      </aside>
      <main class="ex-main"><slot /></main>
    </div>
  </body>
</html>
